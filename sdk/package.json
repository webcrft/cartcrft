{
  "name": "@cartcrft/sdk",
  "version": "0.0.0",
  "description": "Cartcrft TypeScript SDK — typed fetch client generated from OpenAPI 3.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ../docs/openapi.json -o src/types/openapi.d.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.11.14",
    "dotenv": "^16.4.7",
    "openapi-typescript": "^7.8.0",
    "pg": "^8.13.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
