# ─── Version control ──────────────────────────────────────────────────────────
.git
.gitignore

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Node / pnpm ──────────────────────────────────────────────────────────────
node_modules
**/node_modules
.pnpm-store

# ─── TypeScript build outputs (re-built inside the image) ─────────────────────
**/dist
**/*.tsbuildinfo

# ─── Test artefacts ───────────────────────────────────────────────────────────
**/tests
**/*.test.ts
**/vitest.config.ts
**/.vitest-cache

# ─── Docs / non-runtime content ───────────────────────────────────────────────
docs
mcp
assets
README.md
roadmap.md
tasks.md

# ─── Web / SDK source (separate packages, not in the backend image) ───────────
# Each package's package.json is still copied in the deps stage for workspace
# resolution — only their source / build output is excluded here.  Do NOT
# exclude the package directories wholesale or the deps-stage COPY would fail.
web/src
web/public
web/dist
sdk/src
sdk/dist
sdk/storefront/src
sdk/storefront/dist

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode
.idea
*.DS_Store
*.swp
*.swo

# ─── CI ───────────────────────────────────────────────────────────────────────
.github
