# ─── Version control ──────────────────────────────────────────────────────────
.git
.gitignore

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Node / pnpm ──────────────────────────────────────────────────────────────
node_modules
**/node_modules
.pnpm-store

# ─── TypeScript build outputs (re-built inside the image) ─────────────────────
**/dist
**/*.tsbuildinfo

# ─── Test artefacts ───────────────────────────────────────────────────────────
**/tests
**/*.test.ts
**/vitest.config.ts
**/.vitest-cache

# ─── Docs / non-runtime content ───────────────────────────────────────────────
docs
mcp
assets
README.md
roadmap.md
tasks.md

# ─── SDK source (separate packages, not in the backend image) ─────────────────
# web/src + web/public are NOT excluded: the consolidated image builds the SPA
# and serves it same-origin via @fastify/static. Their dist is still covered by
# the **/dist rule above (rebuilt inside the image).
sdk/dist
sdk/storefront/src
sdk/storefront/dist

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode
.idea
*.DS_Store
*.swp
*.swo

# ─── CI ───────────────────────────────────────────────────────────────────────
.github
