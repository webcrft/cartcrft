{
  "name": "cartcrft-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter backend dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "suite": "pnpm --filter backend suite --",
    "migrate": "pnpm --filter backend migrate",
    "seed": "pnpm --filter backend seed",
    "build:web": "pnpm --filter @cartcrft/web build",
    "dev:web": "pnpm --filter @cartcrft/web dev",
    "screenshots": "pnpm --filter backend exec tsx src/scripts/seed-demo.ts && pnpm --filter @cartcrft/e2e run screenshots && pnpm screenshots:sync",
    "screenshots:sync": "mkdir -p web/public/screenshots && cp docs/screenshots/*.png web/public/screenshots/"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
