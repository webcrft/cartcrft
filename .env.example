# =============================================================================
# Cartcrft — repo-root .env.example
#
# Copy this file to .env and fill in the values for your environment.
# The backend loads .env from the repo root in development (APP_ENV != production).
# Astro/web PUBLIC_* vars are embedded at build time (see web/ build commands).
#
# Legend:
#   [SECRET]  — never commit; never expose to client-side code
#   [PUBLIC]  — safe to embed in built JS (Astro PUBLIC_* prefix required)
#   [OPTIONAL]— backend starts without it; feature degrades gracefully
#   [REQUIRED]— backend refuses to start without it
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────────────

# Application environment.  "production" enables all production guards.
APP_ENV=development

# HTTP port the backend API listens on.
# [OPTIONAL] — defaults to 8080.  Do not change unless your infra requires it.
PORT=8080

# URL of the frontend/dashboard (used for CORS allow-list and email links).
# [OPTIONAL] — defaults to http://localhost:5173.
FRONTEND_URL=http://localhost:4321


# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, local PG, etc.).
# [REQUIRED] [SECRET]
DATABASE_URL=postgresql://user:password@host:5432/cartcrft


# ─────────────────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────────────────

# HS256 JWT signing secret.  Minimum 32 chars in production.
# Generate: openssl rand -hex 32
# [REQUIRED] [SECRET]
JWT_SECRET=

# JWT lifetime in hours.  [OPTIONAL] default 24.
JWT_EXPIRY_HOURS=24

# AES-256-GCM key for encrypting provider credentials at rest.
# Required when APP_ENV=production.
# Generate: openssl rand -hex 32
# [OPTIONAL in dev, REQUIRED in prod] [SECRET]
AUTH_SECRETS_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Web / frontend build vars  (Astro PUBLIC_* — embedded at build time)
# ─────────────────────────────────────────────────────────────────────────────
# Set these before running `pnpm --filter @cartcrft/web build`.
# They are inlined into the built JS by Vite and are therefore NOT secrets.

# Base URL of the Cartcrft backend API that the dashboard SPA calls.
# [PUBLIC] — falls back to http://localhost:8080 when unset.
PUBLIC_API_URL=http://localhost:8080

# Enable cloud billing/account pages in the web bundle.
# Set to "1" for a Cartcrft Cloud build; omit entirely for an OSS build.
# When unset, cloud JS chunks (Billing, Account, CloudOnboarding) are
# tree-shaken from the output by Vite.
# [PUBLIC] [OPTIONAL]
PUBLIC_CARTCRFT_CLOUD=


# ─────────────────────────────────────────────────────────────────────────────
# Cloud billing layer  (server-side only; requires CARTCRFT_CLOUD=1)
# ─────────────────────────────────────────────────────────────────────────────
# These are server-side env vars — different from the PUBLIC_CARTCRFT_CLOUD
# build-time flag above.  Both must be set for a full cloud deployment.

# Enable the cloud billing worker and billing webhook route in the backend.
# [OPTIONAL] [SECRET equivalent — treat as server config]
CARTCRFT_CLOUD=

# Paystack secret key used for cloud subscription billing (ZAR charges).
# Also used as the default BYO payment provider key when no per-store key is set.
# [OPTIONAL at boot; required to process cloud subscriptions] [SECRET]
PAYSTACK_SECRET_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Email (AWS Simple Email Service)
# ─────────────────────────────────────────────────────────────────────────────
# All four vars required to enable SES email delivery.
# When any is absent, the backend falls back to a console mailer (stdout).

# [OPTIONAL] [SECRET]
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1
EMAIL_FROM=noreply@cartcrft.com


# ─────────────────────────────────────────────────────────────────────────────
# Exchange rates
# ─────────────────────────────────────────────────────────────────────────────
# Required for live USD→ZAR conversion in cloud billing invoices.
# [OPTIONAL] [SECRET]
EXCHANGE_RATE_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting / caching
# ─────────────────────────────────────────────────────────────────────────────
# Optional Redis URL.  Without it, the backend uses in-memory rate limiting
# and Postgres advisory locks (fine for single-instance deployments).
# [OPTIONAL] [SECRET if Redis requires auth]
REDIS_URL=

# Requests per IP per minute.  [OPTIONAL] default 60.
IP_RATE_LIMIT_PER_MINUTE=60


# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins beyond FRONTEND_URL.
# [OPTIONAL]
CORS_ORIGINS=


# ─────────────────────────────────────────────────────────────────────────────
# Billing simulation (development / CI only)
# ─────────────────────────────────────────────────────────────────────────────
# NEVER enable in production — the backend refuses to start if both are set.

# [OPTIONAL — dev/CI only]
BILLING_SIM_ENABLED=false
# Compressed billing day length in seconds.  [OPTIONAL] default 86400 (real day).
BILLING_SIM_DAY_SECONDS=86400
