        </div>

        <!-- Mobile hamburger button -->
        <button class="hamburger" id="hamburger-btn" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>

      <!-- Mobile dropdown menu -->
      <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation" hidden>
        <a href="/quickstart">Docs</a>
        <a href="/compare">Compare</a>
        <a href="/pricing">Pricing</a>
        {CLOUD && <a href="/cloud/overview">Cloud</a>}
        <a href="https://github.com/webcrft/cartcrft" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" style="display:inline;vertical-align:-2px;margin-right:6px">
            <path fill="currentColor"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483
                 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466
                 -.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832
                 .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688
                 -.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1
                 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595
                 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012
                 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
        <div class="mobile-cta">
          <a href="/dashboard" class="mobile-cta-login">Log in</a>
          {CLOUD
            ? <a href="/dashboard/cloud/onboarding" class="cc-btn-primary">Sign up</a>
            : <a href="/quickstart" class="cc-btn-primary">Get started</a>
          }
        </div>
      </nav>
    </header>

    <!-- ─── Page Content ─────────────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ─── Site Footer ─────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" aria-label="Cartcrft home">
            <img src="/logo-wordmark.svg" alt="Cartcrft" height="30" width="auto" class="footer-logo" />
          </a>
          <p class="footer-tagline">Headless commerce for<br/>agent-native storefronts.</p>
          <!-- GitHub icon-link in footer -->
          <a
            href="https://github.com/webcrft/cartcrft"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-github"
            aria-label="View Cartcrft on GitHub"
          >
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
              <path fill="currentColor"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483
                   0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466
                   -.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832
                   .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688
                   -.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1
                   2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595
                   1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012
                   2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Star on GitHub
          </a>
          <p class="footer-attribution">A <a href="https://webcrft.systems" target="_blank" rel="noopener noreferrer">Webcrft Systems</a> project.</p>
        </div>

        <div class="footer-links">
          <div class="footer-col">
            <h3>Product</h3>
            <ul>
              <li><a href="/pricing">Pricing</a></li>
              <li><a href="/compare">Compare</a></li>
              <li><a href="/dashboard">Dashboard</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h3>Docs</h3>
            <ul>
              <li><a href="/quickstart">Quickstart</a></li>
              <li><a href="/quickstart-mcp">Agent quickstart</a></li>
              <li><a href="/agent-native">Agent-native</a></li>
              <li><a href="/self-host">Self-hosting</a></li>
              <li><a href="/api-overview">API Reference</a></li>
            </ul>
          </div>
          {CLOUD && (
            <div class="footer-col">
              <h3>Cloud</h3>
              <ul>
                <li><a href="/cloud/overview">Cloud Overview</a></li>
                <li><a href="/cloud/billing">Billing &amp; Pricing</a></li>
                <li><a href="/dashboard/cloud/onboarding">Get Started</a></li>
              </ul>
            </div>
          )}
          <div class="footer-col">
            <h3>Community</h3>
            <ul>
              <li>
                <a href="https://github.com/webcrft/cartcrft" target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true" style="display:inline;vertical-align:-1px;margin-right:4px">
                    <path fill="currentColor"
                      d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483
                         0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466
                         -.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832
                         .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688
                         -.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1
                         2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595
                         1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012
                         2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                  </svg>
                  GitHub
                </a>
              </li>
              <li><a href="/contributing">Contributing</a></li>
              <li><a href="/byo-keys">BYO Keys</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h3>Legal</h3>
            <ul>
              <li><a href="/legal/terms">Terms of Service</a></li>
              <li><a href="/legal/privacy">Privacy Policy</a></li>
              <li><a href="/legal/popia">POPIA</a></li>
              <li><a href="/legal/gdpr">GDPR</a></li>
            </ul>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="footer-copyright">&copy; {new Date().getFullYear()} Webcrft Systems (Pty) Ltd. All rights reserved.</p>
        <p class="footer-mit">MIT licensed · Zero take rate · Self-host or cloud</p>
      </div>
    </footer>

    <!-- Hamburger toggle script -->
    <script>
      const btn = document.getElementById('hamburger-btn');
      const menu = document.getElementById('mobile-menu');

      if (btn && menu) {
        btn.addEventListener('click', () => {
          const isOpen = !menu.hidden;
          menu.hidden = isOpen;
          btn.setAttribute('aria-expanded', String(!isOpen));
          btn.classList.toggle('is-open', !isOpen);
        });

        // Close on outside click
        document.addEventListener('click', (e) => {
          if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
            menu.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
            btn.classList.remove('is-open');
          }
        });

        // Close on Escape
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !menu.hidden) {
            menu.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
            btn.classList.remove('is-open');
            btn.focus();
          }
        });
      }

      // Sticky header: add scrolled class for stronger shadow
      const header = document.getElementById('site-header');
      if (header) {
        window.addEventListener('scroll', () => {
          header.classList.toggle('is-scrolled', window.scrollY > 8);
        }, { passive: true });
      }

      // Scroll-reveal: fade + rise sections into view as they enter the viewport.
      const reveals = Array.from(document.querySelectorAll('[data-reveal]'));
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reveals.length) {
        if (prefersReduced || !('IntersectionObserver' in window)) {
          reveals.forEach((el) => el.classList.add('is-revealed'));
        } else {
          const io = new IntersectionObserver((entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                obs.unobserve(entry.target);
              }
            });
          }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
          reveals.forEach((el) => io.observe(el));
        }
      }
    </script>
  </body>
</html>

<style>
  /* ─── Header ─────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(226, 232, 240, 0.8);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .site-header.is-scrolled {
    box-shadow: 0 2px 16px rgba(99, 102, 241, 0.08);
    border-bottom-color: rgba(226, 232, 240, 1);
  }

  @media (prefers-color-scheme: dark) {
    .site-header {
      background: rgba(15, 23, 42, 0.88);
      border-bottom-color: rgba(30, 41, 59, 0.8);
    }
    .site-header.is-scrolled {
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.4);
      border-bottom-color: rgba(30, 41, 59, 1);
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
  }

  .header-logo img {
    height: 28px;
    width: auto;
    display: block;
  }

  /* Desktop nav */
  .header-nav {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    flex: 1;
    justify-content: center;
  }

  .header-nav a {
    font-size: 0.9rem;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    padding: 0.35rem 0.65rem;
    border-radius: 0.4rem;
    transition: color 0.15s, background 0.15s;
  }

  .header-nav a:hover {
    color: #6366f1;
    background: color-mix(in srgb, #6366f1 6%, transparent);
  }

  @media (prefers-color-scheme: dark) {
    .header-nav a { color: #94a3b8; }
    .header-nav a:hover { color: #818cf8; background: color-mix(in srgb, #6366f1 10%, transparent); }
  }

  /* GitHub icon-link in nav */
  .nav-github {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-github svg {
    flex-shrink: 0;
  }

  .nav-github-label {
    /* visible on wider screens only */
  }

  @media (max-width: 900px) {
    .nav-github-label { display: none; }
  }

  /* CTA group */
  .header-cta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .header-login {
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    padding: 0.35rem 0.5rem;
    border-radius: 0.4rem;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .header-login:hover { color: #6366f1; }

  @media (prefers-color-scheme: dark) {
    .header-login { color: #94a3b8; }
    .header-login:hover { color: #818cf8; }
  }

  .cc-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1.1rem;
    background: linear-gradient(135deg, #6366f1 0%, #14b8a6 100%);
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.15s ease, transform 0.1s ease;
    white-space: nowrap;
  }

  .cc-btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 0.4rem;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 0.4rem;
    transition: background 0.15s;
    flex-shrink: 0;
  }

  .hamburger:hover { background: color-mix(in srgb, #6366f1 8%, transparent); }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: #475569;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  @media (prefers-color-scheme: dark) {
    .hamburger-line { background: #94a3b8; }
  }

  .hamburger.is-open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .hamburger.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .header-nav { display: none; }
    .header-login { display: none; }
    .cc-btn-primary { display: none; }
  }

  /* Mobile dropdown */
  .mobile-menu {
    border-top: 1px solid #e2e8f0;
    background: #fff;
    padding: 0.75rem 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .mobile-menu[hidden] { display: none; }

  @media (prefers-color-scheme: dark) {
    .mobile-menu {
      background: #0f172a;
      border-top-color: #1e293b;
    }
  }

  .mobile-menu a {
    display: block;
    font-size: 1rem;
    font-weight: 500;
    color: #334155;
    text-decoration: none;
    padding: 0.65rem 0.5rem;
    border-radius: 0.5rem;
    transition: background 0.12s, color 0.12s;
  }

  .mobile-menu a:hover {
    background: color-mix(in srgb, #6366f1 7%, transparent);
    color: #6366f1;
  }

  @media (prefers-color-scheme: dark) {
    .mobile-menu a { color: #cbd5e1; }
    .mobile-menu a:hover { color: #818cf8; }
  }

  .mobile-cta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding-top: 0.75rem;
    border-top: 1px solid #e2e8f0;
    margin-top: 0.5rem;
  }

  @media (prefers-color-scheme: dark) {
    .mobile-cta { border-top-color: #1e293b; }
  }

  .mobile-cta-login {
    font-size: 0.9rem;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
  }

  @media (prefers-color-scheme: dark) {
    .mobile-cta-login { color: #94a3b8; }
  }

  /* On wider screens, hide mobile menu regardless of hidden attr */
  @media (min-width: 769px) {
    .mobile-menu { display: none !important; }
  }

  /* ─── Footer ─────────────────────────────────────────────────── */
  .site-footer {
    background: #0a0f1e;
    color: #94a3b8;
    margin-top: 6rem;
    border-top: 1px solid #1e293b;
  }

  .footer-inner {
    display: flex;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    flex: 0 0 200px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    /* wordmark on dark bg: the SVG has light text via fill="#0f172a" which is dark;
       we invert so it reads white on dark footer. */
    filter: brightness(0) invert(1);
    opacity: 0.9;
    height: 30px;
    width: auto;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.55;
    color: #64748b;
    margin: 0;
  }

  /* GitHub link in footer brand */
  .footer-github {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: #818cf8;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-github:hover { color: #a5b4fc; }

  .footer-attribution {
    font-size: 0.78rem;
    color: #475569;
    margin: 0;
  }

  .footer-attribution a {
    color: #818cf8;
    text-decoration: none;
  }

  .footer-attribution a:hover { text-decoration: underline; }

  .footer-links {
    display: flex;
    gap: 2.5rem;
    flex: 1;
    flex-wrap: wrap;
  }

  .footer-col {
    min-width: 120px;
  }

  .footer-col h3 {
    font-size: 0.72rem;
