---
/**
 * MarketingLayout — shared shell for all marketing pages (/, /compare, /pricing, /legal/*).
 * Docs pages use Starlight's own layout (configured in astro.config.mjs).
 *
 * Props:
 *   title       — <title> tag content (appended with "| Cartcrft")
 *   description — <meta name="description"> content
 */
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Headless commerce for agent-native storefronts.' } = Astro.props;
const pageTitle = `${title} | Cartcrft`;
// Cloud feature flag — PUBLIC_* vars are available at build time in Astro
const CLOUD = Boolean(import.meta.env.PUBLIC_CARTCRFT_CLOUD);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6366f1" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <style is:global>
      /* Import global styles */
      @import '/src/styles/global.css';
    </style>
  </head>
  <body>
    <!-- ─── Site Header ─────────────────────────────────────────── -->
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="header-logo" aria-label="Cartcrft home">
          <img src="/logo-wordmark.svg" alt="Cartcrft" height="28" width="auto" />
        </a>

        <nav class="header-nav" aria-label="Main navigation">
          <a href="/quickstart">Docs</a>
          <a href="/pricing">Pricing</a>
          <a href="/compare">Compare</a>
          {CLOUD && <a href="/cloud/overview">Cloud</a>}
          <a
            href="https://github.com/webcrftsystems/cartcrft"
            target="_blank"
            rel="noopener noreferrer"
          >GitHub</a>
        </nav>

        <div class="header-cta">
          <a href="/dashboard" class="header-login">Log in</a>
          {CLOUD
            ? <a href="/dashboard/cloud/onboarding" class="cc-btn-primary">Sign up</a>
            : <a href="/quickstart" class="cc-btn-primary">Get started</a>
          }
        </div>
      </div>
    </header>

    <!-- ─── Page Content ─────────────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ─── Site Footer ─────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <img src="/logo.svg" alt="Cartcrft" height="32" />
          <p class="footer-tagline">Headless commerce for agent-native storefronts.</p>
          <p class="footer-attribution">A <a href="https://webcrft.systems" target="_blank" rel="noopener noreferrer">Webcrft Systems</a> project.</p>
        </div>

        <div class="footer-links">
          <div class="footer-col">
            <h3>Product</h3>
            <ul>
              <li><a href="/quickstart">Documentation</a></li>
              <li><a href="/pricing">Pricing</a></li>
              <li><a href="/compare">Compare</a></li>
              <li><a href="/quickstart">Quickstart</a></li>
              <li><a href="/dashboard">Dashboard</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h3>Guides</h3>
            <ul>
              <li><a href="/agent-native">Agent-Native</a></li>
              <li><a href="/self-host">Self-hosting</a></li>
              <li><a href="/byo-keys">BYO Keys</a></li>
              <li><a href="/api-overview">API Reference</a></li>
            </ul>
          </div>
          {CLOUD && (
            <div class="footer-col">
              <h3>Cloud</h3>
              <ul>
                <li><a href="/cloud/overview">Cloud Overview</a></li>
                <li><a href="/cloud/billing">Billing & Pricing</a></li>
                <li><a href="/dashboard/cloud/onboarding">Get Started</a></li>
              </ul>
            </div>
          )}
          <div class="footer-col">
            <h3>Community</h3>
            <ul>
              <li><a href="https://github.com/webcrftsystems/cartcrft" target="_blank" rel="noopener noreferrer">GitHub</a></li>
              <li><a href="/contributing">Contributing</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h3>Legal</h3>
            <ul>
              <li><a href="/legal/terms">Terms of Service</a></li>
              <li><a href="/legal/privacy">Privacy Policy</a></li>
              <li><a href="/legal/popia">POPIA</a></li>
              <li><a href="/legal/gdpr">GDPR</a></li>
            </ul>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Webcrft Systems (Pty) Ltd. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  /* ─── Header ─────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #e2e8f0;
  }

  @media (prefers-color-scheme: dark) {
    .site-header {
      background: rgba(15, 23, 42, 0.9);
      border-bottom-color: #1e293b;
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
  }

  .header-logo img {
    height: 28px;
    width: auto;
  }

  .header-nav {
    display: flex;
    gap: 1.75rem;
    align-items: center;
  }

  .header-nav a {
    font-size: 0.9rem;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    transition: color 0.15s;
  }

  .header-nav a:hover {
    color: #6366f1;
  }

  @media (prefers-color-scheme: dark) {
    .header-nav a { color: #94a3b8; }
    .header-nav a:hover { color: #818cf8; }
  }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header-login {
    font-size: 0.9rem;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    transition: color 0.15s;
  }

  .header-login:hover {
    color: #6366f1;
  }

  @media (prefers-color-scheme: dark) {
    .header-login { color: #94a3b8; }
    .header-login:hover { color: #818cf8; }
  }

  .cc-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.2rem;
    background: linear-gradient(135deg, #6366f1 0%, #14b8a6 100%);
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.15s ease, transform 0.1s ease;
    white-space: nowrap;
  }

  .cc-btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .header-nav { display: none; }
  }

  /* ─── Footer ─────────────────────────────────────────────────── */
  .site-footer {
    background: #0f172a;
    color: #94a3b8;
    margin-top: 6rem;
  }

  .footer-inner {
    display: flex;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    flex: 0 0 220px;
  }

  .footer-brand img {
    /* logo.svg on dark bg - the SVG uses dark text; invert it */
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  .footer-tagline {
    margin-top: 1rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #64748b;
  }

  .footer-attribution {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: #475569;
  }

  .footer-attribution a {
    color: #818cf8;
    text-decoration: none;
  }

  .footer-attribution a:hover {
    text-decoration: underline;
  }

  .footer-links {
    display: flex;
    gap: 3rem;
    flex: 1;
    flex-wrap: wrap;
  }

  .footer-col h3 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #f8fafc;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: #64748b;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: #818cf8;
  }

  .footer-bottom {
    border-top: 1px solid #1e293b;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem;
    font-size: 0.8rem;
    color: #475569;
  }
</style>
