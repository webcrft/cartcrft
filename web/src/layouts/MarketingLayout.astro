---
/**
 * MarketingLayout — shared shell for all marketing pages (/, /compare, /pricing, /legal/*).
 * Docs pages use Starlight's own layout (configured in astro.config.mjs).
 *
 * Props:
 *   title       — <title> tag content (appended with "| Cartcrft")
 *   description — <meta name="description"> content
 *   ogImage     — OG image path (default: /og-image.svg)
 *   canonical   — full canonical URL (default: derived from current URL)
 */
import SEO from '../components/SEO.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description = 'Headless commerce for agent-native storefronts.', ogImage, canonical } = Astro.props;
const pageTitle = `${title} | Cartcrft`;
// Cloud feature flag — PUBLIC_* vars are available at build time in Astro
const CLOUD = Boolean(import.meta.env.PUBLIC_CARTCRFT_CLOUD);
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Swap no-js → js immediately so reveal animations only arm when JS is present -->
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>

    <!-- SEO + OG + Twitter meta (all in one component) -->
    <SEO
      title={pageTitle}
      description={description}
      ogImage={ogImage}
      canonical={canonical}
    />

    <style is:global>
      @import '/src/styles/global.css';
    </style>
  </head>
  <body>
    <!-- ─── Site Header ─────────────────────────────────────────── -->
    <header class="site-header" id="site-header">
      <div class="header-inner">

        <!-- Logo / wordmark -->
        <a href="/" class="header-logo" aria-label="Cartcrft home">
          <img src="/logo-wordmark.svg" alt="Cartcrft" height="28" width="auto" />
        </a>

        <!-- Desktop nav -->
        <nav class="header-nav" aria-label="Main navigation">
          <a href="/quickstart">Docs</a>
          <a href="/compare">Compare</a>
          <a href="/pricing">Pricing</a>
          {CLOUD && <a href="/cloud/overview">Cloud</a>}
          <!-- GitHub icon-link -->
          <a
            href="https://github.com/webcrft/cartcrft"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-github"
            aria-label="View Cartcrft on GitHub"
          >
            <!-- GitHub SVG logo (inline) -->
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
              <path fill="currentColor"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483
                   0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466
                   -.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832
                   .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688
                   -.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1
                   2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595
                   1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012
                   2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            <span class="nav-github-label">GitHub</span>
          </a>
        </nav>

        <!-- CTA group -->
        <div class="header-cta">
          <a href="/dashboard" class="header-login">Log in</a>
          {CLOUD
            ? <a href="/dashboard/cloud/onboarding" class="cc-btn-primary">Sign up</a>
            : <a href="/quickstart" class="cc-btn-primary">Get started</a>
