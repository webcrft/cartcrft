---
/**
 * LegalLayout — wrapper for /legal/* pages.
 * Applies MarketingLayout and adds standard legal page chrome.
 *
 * Props:
 *   title       — document title (e.g. "Terms of Service")
 *   description — meta description
 *   lastUpdated — ISO date string, e.g. "2026-06-01"
 */
export interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}

import MarketingLayout from './MarketingLayout.astro';

const { title, description, lastUpdated } = Astro.props;
---

<MarketingLayout title={title} description={description}>
  <!-- Draft banner — rendered at the very top of every legal page until counsel finalises -->
  <div class="draft-banner" role="alert" aria-live="polite">
    <span class="draft-badge">DRAFT</span>
    <span class="draft-text">
      This document is <strong>pending legal review and is not yet in force.</strong>
      It must not be relied upon as a binding policy until approved by qualified legal counsel.
    </span>
  </div>

  <article class="legal-page">
    <header class="legal-header">
      <div class="legal-header-inner">
        <div class="legal-breadcrumb">
          <a href="/">Cartcrft</a>
          <span aria-hidden="true">›</span>
          <a href="/legal/terms">Legal</a>
          <span aria-hidden="true">›</span>
          <span>{title}</span>
        </div>
        <h1>{title}</h1>
        {lastUpdated && (
          <p class="last-updated">Last updated: <time datetime={lastUpdated}>{lastUpdated}</time></p>
        )}
      </div>
    </header>

    <div class="legal-body">
      <div class="legal-content">
        <slot />
      </div>

      <aside class="legal-nav">
        <h2>Legal</h2>
        <ul>
          <li><a href="/legal/terms">Terms of Service</a></li>
          <li><a href="/legal/privacy">Privacy Policy</a></li>
          <li><a href="/legal/popia">POPIA</a></li>
          <li><a href="/legal/gdpr">GDPR</a></li>
        </ul>
      </aside>
    </div>
  </article>
</MarketingLayout>

<style>
  /* ── Draft banner ─────────────────────────────────────────────────────────── */
  .draft-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #7c3aed;
    color: #fff;
    padding: 0.85rem 1.5rem;
    font-size: 0.875rem;
    line-height: 1.5;
    flex-wrap: wrap;
  }

  .draft-badge {
    flex-shrink: 0;
    background: #fff;
    color: #7c3aed;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }

  .draft-text {
    flex: 1;
    min-width: 0;
  }

  @media (prefers-color-scheme: dark) {
    .draft-banner {
      background: #4c1d95;
    }
    .draft-badge {
      background: #c4b5fd;
      color: #1e0757;
    }
  }

  /* ── Legal header ─────────────────────────────────────────────────────────── */
  .legal-header {
    padding: 4rem 1.5rem 2rem;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
  }

  @media (prefers-color-scheme: dark) {
    .legal-header {
      background: #1e293b;
      border-bottom-color: #334155;
    }
  }

  .legal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .legal-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #64748b;
    margin-bottom: 1rem;
  }

  .legal-breadcrumb a {
    color: #6366f1;
    text-decoration: none;
  }

  .legal-breadcrumb a:hover {
    text-decoration: underline;
  }

  .legal-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  @media (prefers-color-scheme: dark) {
    .legal-header h1 { color: #f8fafc; }
  }

  .last-updated {
    font-size: 0.875rem;
    color: #64748b;
  }

  .legal-body {
    display: flex;
    gap: 4rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    align-items: flex-start;
  }

  .legal-content {
    flex: 1;
    min-width: 0;
    /* Prose styles */
    font-size: 0.95rem;
    line-height: 1.75;
    color: #334155;
  }

  @media (prefers-color-scheme: dark) {
    .legal-content { color: #cbd5e1; }
  }

  .legal-content :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    color: #0f172a;
    margin: 2.5rem 0 0.75rem;
  }

  @media (prefers-color-scheme: dark) {
    .legal-content :global(h2) { color: #f1f5f9; }
  }

  .legal-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1e293b;
    margin: 1.75rem 0 0.5rem;
  }

  @media (prefers-color-scheme: dark) {
    .legal-content :global(h3) { color: #e2e8f0; }
  }

  .legal-content :global(p) {
    margin-bottom: 1rem;
  }

  .legal-content :global(ul),
  .legal-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .legal-content :global(li) {
    margin-bottom: 0.35rem;
  }

  .legal-content :global(a) {
    color: #6366f1;
    text-decoration: underline;
  }

  .legal-content :global(strong) {
    font-weight: 700;
    color: #0f172a;
  }

  @media (prefers-color-scheme: dark) {
    .legal-content :global(strong) { color: #f1f5f9; }
  }

  /* Sidebar nav */
  .legal-nav {
    flex: 0 0 220px;
    position: sticky;
    top: 80px;
    padding: 1.25rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    background: #f8fafc;
  }

  @media (prefers-color-scheme: dark) {
    .legal-nav {
      border-color: #1e293b;
      background: #1e293b;
    }
  }

  @media (max-width: 768px) {
    .legal-body { flex-direction: column; }
    .legal-nav { position: static; width: 100%; }
  }

  .legal-nav h2 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #64748b;
    margin-bottom: 0.75rem;
  }

  .legal-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .legal-nav a {
    font-size: 0.875rem;
    color: #475569;
    text-decoration: none;
    display: block;
    padding: 0.3rem 0.5rem;
    border-radius: 0.35rem;
    transition: background 0.1s, color 0.1s;
  }

  .legal-nav a:hover {
    background: color-mix(in srgb, #6366f1 8%, transparent);
    color: #6366f1;
  }

  @media (prefers-color-scheme: dark) {
    .legal-nav a { color: #94a3b8; }
    .legal-nav a:hover { color: #818cf8; }
  }
</style>
