---
/**
 * Compare page — /compare
 * Content (intro, narrative sections, sources) is driven from
 * src/content/marketing/compare.md via the "marketing" Astro content collection.
 *
 * Competitor table data stays here as structured data (not prose) so it can
 * be rendered by ComparisonTable. This is the right split: prose is MD-authored,
 * structured tables are component-rendered.
 *
 * Grounded comparison. All competitor facts are dated and sourced.
 * Sources (all verified June 2026):
 *  - Shopify pricing/fees: shopify.com/pricing
 *  - Medusa Cloud pricing: medusajs.com/pricing/
 *  - Saleor Cloud pricing: saleor.io/pricing
 *  - Swell pricing: swell.is/pricing
 *  - Vendure: vendure.io/pricing + github.com/vendure-ecommerce/vendure
 *  - WooCommerce: wordpress.org/plugins/woocommerce
 *  - Shopify agentic commerce: shopify.com/blog/how-agentic-commerce-works (published April 30, 2026)
 */
import { getEntry, render } from 'astro:content';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import ComparisonTable from '../components/ComparisonTable.astro';

// Load the compare content from the marketing collection
const compareEntry = await getEntry('marketing', 'compare');
if (!compareEntry) throw new Error('compare.md not found in marketing collection');
const { Content } = await render(compareEntry);

const competitors = ['Cartcrft', 'Shopify', 'Medusa v2', 'Vendure', 'Saleor', 'Swell', 'WooCommerce'];

const rows = [
  // License and ownership
  {
    category: 'License & ownership',
    feature: 'Core license',
    values: {
      'Cartcrft':    'MIT',
      'Shopify':     'Closed / SaaS',
      'Medusa v2':   'MIT',
      'Vendure':     'GPLv3 (core)',
      'Saleor':      'BSD-3-Clause',
      'Swell':       'Closed / SaaS',
      'WooCommerce': 'GPL-2.0+',
    },
    highlight: true,
  },
  {
    category: 'License & ownership',
    feature: 'Self-hostable',
    values: {
      'Cartcrft':    true,
      'Shopify':     false,
      'Medusa v2':   true,
      'Vendure':     true,
      'Saleor':      true,
      'Swell':       false,
      'WooCommerce': true,
    },
  },
  {
    category: 'License & ownership',
    feature: 'Source available / open',
    values: {
      'Cartcrft':    true,
      'Shopify':     false,
      'Medusa v2':   true,
      'Vendure':     true,
      'Saleor':      true,
      'Swell':       false,
      'WooCommerce': true,
    },
  },

  // Pricing and fees
  {
    category: 'Pricing & fees',
    feature: 'Transaction fee (external gateway)',
    values: {
      'Cartcrft':    '0%',
      'Shopify':     '0.6%–2% (varies by plan)',
      'Medusa v2':   '0%',
      'Vendure':     '0%',
      'Saleor':      '0%',
      'Swell':       '0%',
      'WooCommerce': '0%',
    },
    highlight: true,
  },
  {
    category: 'Pricing & fees',
    feature: 'Managed cloud entry price',
    values: {
      'Cartcrft':    'Flat fee (contact)',
      'Shopify':     '$29/mo (Basic)',
      'Medusa v2':   '$29/mo (Develop)',
      'Vendure':     'GA Q4 2026 (design partners)',
      'Saleor':      '$1,599/mo (Select)',
      'Swell':       '$29/mo (Starter, billed annually)',
      'WooCommerce': 'N/A (self-host only)',
    },
  },
  {
    category: 'Pricing & fees',
    feature: 'GMV / revenue percentage',
    values: {
      'Cartcrft':    '0%',
      'Shopify':     null,
      'Medusa v2':   '0%',
      'Vendure':     '0% (flat Platform fee)',
      'Saleor':      '0.4%–0.8% overage above GMV cap',
      'Swell':       '0.4%–2% overage above revenue ceiling',
      'WooCommerce': '0%',
    },
  },

  // Agent-native
  {
    category: 'Agent-native',
    feature: 'MCP server (built-in)',
    values: {
      'Cartcrft':    'Shipped',
      'Shopify':     'Shipped (Storefront MCP, Apr 2026)',
      'Medusa v2':   false,
      'Vendure':     false,
      'Saleor':      false,
      'Swell':       false,
      'WooCommerce': false,
    },
    highlight: true,
  },
  {
    category: 'Agent-native',
    feature: 'ACP adapter (Agentic Commerce Protocol)',
    values: {
      'Cartcrft':    'Shipped (test mode)',
      'Shopify':     'Via ChatGPT Buy / ACP standard',
      'Medusa v2':   false,
      'Vendure':     false,
      'Saleor':      false,
      'Swell':       false,
      'WooCommerce': false,
    },
    highlight: true,
  },
  {
    category: 'Agent-native',
    feature: 'UCP adapter (Universal Commerce Protocol)',
    values: {
      'Cartcrft':    'Shipped (test mode)',
      'Shopify':     'Shipped (UCP co-author, NRF 2026)',
      'Medusa v2':   false,
      'Vendure':     false,
      'Saleor':      false,
      'Swell':       false,
      'WooCommerce': false,
    },
    highlight: true,
  },
  {
    category: 'Agent-native',
    feature: 'Live delegated / agentic payment',
    values: {
      'Cartcrft':    'In development (Phase H5)',
      'Shopify':     'Live (US merchants, Apr 2026)',
      'Medusa v2':   false,
      'Vendure':     false,
      'Saleor':      false,
      'Swell':       false,
      'WooCommerce': false,
    },
  },
  {
    category: 'Agent-native',
    feature: 'Signed agent mandates (ed25519)',
    values: {
      'Cartcrft':    true,
      'Shopify':     false,
      'Medusa v2':   false,
      'Vendure':     false,
      'Saleor':      false,
      'Swell':       false,
      'WooCommerce': false,
    },
    highlight: true,
  },
  {
    category: 'Agent-native',
    feature: 'Semantic / vector search (built-in)',
    values: {
      'Cartcrft':    true,
      'Shopify':     'Paid add-on',
      'Medusa v2':   false,
      'Vendure':     false,
      'Saleor':      false,
      'Swell':       false,
      'WooCommerce': false,
    },
  },

  // API and architecture
  {
    category: 'API & architecture',
    feature: 'REST API',
    values: {
      'Cartcrft':    true,
      'Shopify':     true,
      'Medusa v2':   true,
      'Vendure':     false,
      'Saleor':      false,
      'Swell':       true,
      'WooCommerce': true,
    },
  },
  {
    category: 'API & architecture',
    feature: 'GraphQL API',
    values: {
      'Cartcrft':    false,
      'Shopify':     true,
      'Medusa v2':   false,
      'Vendure':     true,
      'Saleor':      true,
      'Swell':       true,
      'WooCommerce': 'Plugin',
    },
  },
  {
    category: 'API & architecture',
    feature: 'Fully headless (API-only core)',
    values: {
      'Cartcrft':    true,
      'Shopify':     true,
      'Medusa v2':   true,
      'Vendure':     true,
      'Saleor':      true,
      'Swell':       true,
      'WooCommerce': 'Via plugin',
    },
  },
  {
    category: 'API & architecture',
    feature: 'Primary language',
    values: {
      'Cartcrft':    'TypeScript',
      'Shopify':     'Ruby / closed',
      'Medusa v2':   'TypeScript',
      'Vendure':     'TypeScript',
      'Saleor':      'Python',
      'Swell':       'Closed / Node.js',
      'WooCommerce': 'PHP',
    },
  },
  {
    category: 'API & architecture',
    feature: 'Postgres-native',
    values: {
      'Cartcrft':    true,
      'Shopify':     null,
      'Medusa v2':   true,
      'Vendure':     true,
      'Saleor':      true,
      'Swell':       null,
      'WooCommerce': 'MySQL / MariaDB',
    },
  },

  // Commerce features
  {
    category: 'Commerce features',
    feature: 'B2B (companies, credit, quotes)',
    values: {
      'Cartcrft':    true,
      'Shopify':     'Shopify Plus only ($2,300+/mo)',
      'Medusa v2':   true,
      'Vendure':     'Platform tier',
      'Saleor':      true,
      'Swell':       true,
      'WooCommerce': 'Plugin',
    },
  },
  {
    category: 'Commerce features',
    feature: 'Subscriptions',
    values: {
      'Cartcrft':    true,
      'Shopify':     'App/plugin',
      'Medusa v2':   'In progress',
      'Vendure':     'Plugin',
      'Saleor':      'App',
      'Swell':       true,
      'WooCommerce': 'Paid plugin',
    },
  },
  {
    category: 'Commerce features',
    feature: 'Returns / RMA',
    values: {
      'Cartcrft':    true,
      'Shopify':     true,
      'Medusa v2':   true,
      'Vendure':     'Plugin',
      'Saleor':      true,
      'Swell':       true,
      'WooCommerce': 'Plugin',
    },
  },
  {
    category: 'Commerce features',
    feature: 'Multi-payment providers (BYO)',
    values: {
      'Cartcrft':    'Stripe, Paystack, Razorpay, Xendit',
      'Shopify':     'Limited (surcharge if not Shopify Payments)',
      'Medusa v2':   true,
      'Vendure':     true,
      'Saleor':      true,
      'Swell':       true,
      'WooCommerce': true,
    },
  },
];
---

<MarketingLayout
  title="How Cartcrft compares"
  description="A grounded comparison of Cartcrft vs Shopify, Medusa v2, Vendure, Saleor, Swell, and WooCommerce across licensing, pricing, agent-native capabilities, and commerce features."
>
  <!-- Page header — from content collection frontmatter -->
  <section class="page-header">
    <div class="page-header-inner">
      <div class="page-label">Feature comparison</div>
      <h1>{compareEntry.data.title}</h1>
      <p>{compareEntry.data.description}</p>
      {compareEntry.data.methodology && (
        <p class="methodology">{compareEntry.data.methodology}</p>
      )}
    </div>
  </section>

  <!-- Comparison table (structured data — component-rendered) -->
  <section class="table-section">
    <div class="table-section-inner">
      <ComparisonTable
        competitors={competitors}
        rows={rows}
        ourName="Cartcrft"
        caption="Figures as of June 2026. Verify with official sources before making purchasing decisions."
      />
    </div>
  </section>

  <!-- Narrative sections — rendered from markdown content -->
  <section class="narratives">
    <div class="narratives-inner">
      <div class="md-prose">
        <Content />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="compare-cta">
    <div class="compare-cta-inner">
      <h2>Ready to try Cartcrft?</h2>
      <p>Get a store running and MCP-connected in under 10 minutes.</p>
      <div class="compare-cta-actions">
        <a href="/quickstart" class="btn-primary">Get started free</a>
        <a href="/pricing" class="btn-secondary">See pricing</a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .page-header {
    padding: 5rem 1.5rem 3rem;
    text-align: center;
    background: radial-gradient(
      ellipse 70% 40% at 50% 0%,
      color-mix(in srgb, #6366f1 10%, transparent),
      transparent 60%
    );
  }

  .page-header-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .page-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6366f1;
    margin-bottom: 1rem;
  }

  @media (prefers-color-scheme: dark) {
    .page-label { color: #818cf8; }
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #0f172a;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  @media (prefers-color-scheme: dark) {
    .page-header h1 { color: #f8fafc; }
  }

  .page-header p {
    font-size: 1rem;
    color: #475569;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  @media (prefers-color-scheme: dark) {
    .page-header p { color: #94a3b8; }
  }

  .methodology {
    font-size: 0.85rem !important;
    color: #64748b !important;
    font-style: italic;
    border-top: 1px solid #e2e8f0;
    padding-top: 0.75rem;
    margin-top: 0.75rem;
  }

  @media (prefers-color-scheme: dark) {
    .methodology {
      color: #64748b !important;
      border-top-color: #1e293b;
    }
  }

  .table-section {
    padding: 2rem 1.5rem 3rem;
  }

  .table-section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Narrative / prose section — renders markdown Content */
  .narratives {
    padding: 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .narratives-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Style the rendered markdown prose */
  .md-prose :global(h2) {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 700;
    color: #0f172a;
    margin: 2.5rem 0 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e8f0;
  }

  @media (prefers-color-scheme: dark) {
    .md-prose :global(h2) {
      color: #f1f5f9;
      border-top-color: #1e293b;
    }
  }

  /* First h2 should not have top border */
  .md-prose :global(h2:first-of-type) {
    border-top: none;
    margin-top: 0;
    padding-top: 0;
  }

  /* Hide the h2 "Introduction" heading (it's implied by context) */
  .md-prose :global(h2:first-of-type) {
    display: none;
  }

  /* Display the narrative cards in a 2-col grid (except Sources) */
  .md-prose {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  /* Sources section spans full width */
  .md-prose :global(h2:last-of-type),
  .md-prose :global(h2:last-of-type + p) {
    grid-column: 1 / -1;
  }

  @media (max-width: 768px) {
    .md-prose { grid-template-columns: 1fr; }
  }

  .md-prose :global(p) {
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  @media (prefers-color-scheme: dark) {
    .md-prose :global(p) { color: #94a3b8; }
  }

  /* Wrap each h2 + its following p tags as a card (via CSS sibling counters is hard;
     simpler: wrap the whole grid item logic with a container div from md) */
  /* Instead use a simpler prose-card wrapper approach: each section gets card styling */
  .md-prose :global(h2) {
    border-top: none !important;
    padding-top: 0 !important;
    margin-top: 0 !important;
    /* card header */
    font-size: 1.05rem;
    padding: 1.25rem 1.5rem 0;
    border-radius: 0.75rem 0.75rem 0 0;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-bottom: none;
    margin-bottom: 0;
  }

  @media (prefers-color-scheme: dark) {
    .md-prose :global(h2) {
      background: #0d1426;
      border-color: #1e293b;
    }
  }

  .md-prose :global(p:not(:last-child)) {
    background: #f8fafc;
    border-left: 1px solid #e2e8f0;
    border-right: 1px solid #e2e8f0;
    padding: 0 1.5rem;
    margin-bottom: 0;
  }

  .md-prose :global(p:last-of-type) {
    background: #f8fafc;
    border-left: 1px solid #e2e8f0;
    border-right: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
    border-radius: 0 0 0.75rem 0.75rem;
    padding: 0 1.5rem 1.25rem;
    margin-bottom: 0;
  }

  @media (prefers-color-scheme: dark) {
    .md-prose :global(p:not(:last-child)),
    .md-prose :global(p:last-of-type) {
      background: #0d1426;
      border-color: #1e293b;
    }
  }

  /* Sources section — full width card */
  .md-prose :global(h2:last-of-type) {
    grid-column: 1 / -1;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
  }

  @media (prefers-color-scheme: dark) {
    .md-prose :global(h2:last-of-type) { color: #64748b; }
  }

  .md-prose :global(h2:last-of-type + p) {
    grid-column: 1 / -1;
    font-size: 0.78rem !important;
    color: #64748b !important;
    font-style: italic;
    border-radius: 0 0 0.75rem 0.75rem !important;
  }

  /* CTA */
  .compare-cta {
    background: linear-gradient(135deg, #4f46e5 0%, #0d9488 100%);
    padding: 5rem 1.5rem;
    text-align: center;
    color: #fff;
    margin-top: 4rem;
  }

  .compare-cta-inner {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .compare-cta h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
  }

  .compare-cta p {
    font-size: 1rem;
    opacity: 0.9;
  }

  .compare-cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: #fff;
    color: #4f46e5;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.1s;
  }

  .btn-primary:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.12);
  }
</style>
