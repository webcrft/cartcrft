    ctaPrimary={{ label: 'Get started free', href: '/docs/quickstart' }}
    ctaSecondary={{ label: 'View on GitHub', href: 'https://github.com/webcrftsystems/cartcrft' }}
  />

  <!-- ─── Features ─────────────────────────────────────────────── -->
  <!-- TODO(landing-agent): update heading + subheading copy -->
