---
/**
 * FeatureGrid — a responsive grid of feature cards.
 * TODO(landing-agent): pass the real features array with final copy.
 *
 * Props:
 *   features — array of FeatureItem
 *   columns  — grid column count: 2 | 3 | 4 (default: 3)
 *   heading  — optional section heading
 *   subheading — optional section subheading
 */
export interface FeatureItem {
  /** Emoji or icon string shown at top of card */
  icon: string;
  title: string;
  description: string;
  /** Optional link for the card */
  href?: string;
}

export interface FeatureGridProps {
  features: FeatureItem[];
  columns?: 2 | 3 | 4;
  heading?: string;
  subheading?: string;
}

const {
  features,
  columns = 3,
  heading,
  subheading,
} = Astro.props as FeatureGridProps;
---

<section class="feature-grid-section">
  {(heading || subheading) && (
    <div class="section-header">
      {heading && <h2 class="section-heading">{heading}</h2>}
      {subheading && <p class="section-subheading">{subheading}</p>}
    </div>
  )}

  <ul
    class="feature-grid"
    style={`--cols: ${columns}`}
    role="list"
  >
    {features.map((f) => (
      <li class="feature-card">
        {f.href ? (
          <a href={f.href} class="feature-card-inner feature-card-link">
            <span class="feature-icon" aria-hidden="true">{f.icon}</span>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.description}</p>
          </a>
        ) : (
          <div class="feature-card-inner">
            <span class="feature-icon" aria-hidden="true">{f.icon}</span>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.description}</p>
          </div>
        )}
      </li>
    ))}
  </ul>
</section>

<style>
  .feature-grid-section {
    padding: 4rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #0f172a;
    margin-bottom: 0.75rem;
  }

  @media (prefers-color-scheme: dark) {
    .section-heading { color: #f8fafc; }
  }

  .section-subheading {
    font-size: 1.1rem;
    color: #475569;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  @media (prefers-color-scheme: dark) {
    .section-subheading { color: #94a3b8; }
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 900px) {
    .feature-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .feature-grid { grid-template-columns: 1fr; }
  }

  .feature-card {
    border-radius: 0.75rem;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  @media (prefers-color-scheme: dark) {
    .feature-card {
      border-color: #1e293b;
      background: #0f172a;
    }
  }

  .feature-card:hover {
    border-color: #6366f1;
    box-shadow: 0 4px 20px color-mix(in srgb, #6366f1 15%, transparent);
  }

  .feature-card-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .feature-card-link {
    cursor: pointer;
  }

  .feature-icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
  }

  @media (prefers-color-scheme: dark) {
    .feature-title { color: #f1f5f9; }
  }

  .feature-desc {
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.6;
    flex: 1;
  }

  @media (prefers-color-scheme: dark) {
    .feature-desc { color: #94a3b8; }
  }
</style>
